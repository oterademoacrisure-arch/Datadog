def handle_database_health_monitoring(summary_payload, gdk):
    subject = summary_payload.get('subject', 'Database')
    print(f"\n--- Starting Health Check for {subject} ---")
    
    # 1. Fetch Data using the Client Library
    db_query = f"service:database_service status:error subject:{subject}"
    try:
        raw_logs = gdk.datadog.fetch_logs(db_query)
        log_context = "\n".join(raw_logs) if raw_logs else "No issues found."
    except Exception as e:
        print(f"❌ Connectivity Error: {e}")
        log_context = "Error retrieving logs from Datadog."

    # 2. LLM Analysis
    prompt = f"User Question: {summary_payload['original_question']}\nLogs:\n{log_context}"
    report = gdk.invoke_llmgateway(prompt)
    
    print("\n[FINAL REPORT]")
    print(report)
    return report

