import random
import datetime
import sys

class DummyDatadogLogClient:
    def __init__(self, mode="random"):
        self.mode = mode

    def fetch_logs(self, query):
        print(f"[Dummy] Running query: {query} (mode={self.mode})")

        error_logs = [
            "ERROR: Connection timeout on db-node-1",
            "ERROR: Transaction rollback due to deadlock",
            "ERROR: Authentication failure for user 'reporting_app'",
            "ERROR: Disk I/O saturation detected"
        ]
        warn_logs = [
            "WARN: Query exceeded 1.5s on db-node-2",
            "WARN: Slow index scan detected on table 'orders'",
            "WARN: Replication lag of 2.3s on standby node"
        ]
        info_logs = [
            "INFO: Query completed in 0.8s",
            "INFO: Backup completed successfully",
            "INFO: Connection pool usage at 65%"
        ]

        logs = []
        for _ in range(random.randint(2, 5)):
            timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            if self.mode == "critical":
                logs.append(f"{timestamp} {random.choice(error_logs)}")
            elif self.mode == "warning":
                logs.append(f"{timestamp} {random.choice(warn_logs)}")
            elif self.mode == "healthy":
                logs.append(f"{timestamp} {random.choice(info_logs)}")
            else:  # random mix
                choice = random.choice([error_logs, warn_logs, info_logs])
                logs.append(f"{timestamp} {random.choice(choice)}")
        return logs


class DatabaseAgentGDK:
    def __init__(self, mode="random"):
        self.datadog = DummyDatadogLogClient(mode=mode)

    def invoke_llmgateway(self, prompt):
        print("[Dummy LLM] Prompt received:")
        print(prompt)
        return f"Simulated analysis: Database health evaluated in {self.datadog.mode.upper()} mode."


def handle_database_health_monitoring(summary_payload: dict, gdk_instance: DatabaseAgentGDK):
    print(f"\n[System] Identifying health issues for: {summary_payload.get('subject', 'Database')}")
    db_query = "service:database_service (status:error OR duration:>1s)"
    raw_logs = gdk_instance.datadog.fetch_logs(db_query)
    log_context = "\n".join(raw_logs) if raw_logs else "No critical logs found."

    analysis_prompt = f"""
    User Question: {summary_payload.get('original_question')}

    Relevant Database Logs from Datadog:
    {log_context}

    Task: Based on these logs, explain the current health of the database.
    """

    response = gdk_instance.invoke_llmgateway(analysis_prompt)
    print("\n--- Health Monitoring Report ---")
    print(response)
    return response


def dispatch(use_case: str, summary_payload: dict, gdk: DatabaseAgentGDK):
    if use_case == "Database Health Monitoring":
        return handle_database_health_monitoring(summary_payload, gdk)
    else:
        print("Standard response...")


if __name__ == "__main__":
    # Read mode from command line argument
    mode = sys.argv[1] if len(sys.argv) > 1 else "random"

    summary_payload = {
        "subject": "Payments DB",
        "original_question": "Why is the database slow today?"
    }

    gdk = DatabaseAgentGDK(mode=mode)
    dispatch("Database Health Monitoring", summary_payload, gdk)
